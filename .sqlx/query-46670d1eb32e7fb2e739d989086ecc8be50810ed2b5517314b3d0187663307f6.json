  "query": "\n        SELECT id AS \"id!\", nome AS \"nome!\", logo_url, ativo AS \"ativo!\"\n        FROM parceiros\n        WHERE ($1::text IS NULL OR nome ILIKE '%' || $1 || '%')\n        ORDER BY ordem, nome\n        LIMIT $2 OFFSET $3\n        ",
