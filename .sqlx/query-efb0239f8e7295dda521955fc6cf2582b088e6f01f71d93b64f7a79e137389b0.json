{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT id AS \"id!\", telefone AS \"telefone!\", classificacao AS \"classificacao!\",\n               to_char(created_at, 'DD/MM/YYYY') AS \"inscricao!\"\n        FROM novidades_inscritos\n        WHERE ($1::text IS NULL OR telefone ILIKE '%' || $1 || '%')\n        ORDER BY created_at DESC\n        LIMIT 200\n        ",
