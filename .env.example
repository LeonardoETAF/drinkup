# Copie para `.env` e ajuste. O `.env` real NUNCA é commitado.

# --- PostgreSQL (use o serviço `db` do docker-compose em desenvolvimento) ---
DATABASE_URL=postgres://drinkup:drinkup@localhost:5432/drinkup

# --- Leptos / servidor ---
LEPTOS_SITE_ADDR=127.0.0.1:3000
LEPTOS_SITE_ROOT=target/site
LEPTOS_OUTPUT_NAME=drinkup

# --- Sessão (gere uma chave forte, ex.: `openssl rand -base64 64`) ---
SESSION_SECRET=troque-por-uma-chave-secreta-forte-e-aleatoria

# --- Logs ---
RUST_LOG=info,drinkup=debug

# =====================================================================
# PRODUÇÃO (docker-compose.prod.yml). Em prod, DATABASE_URL é montada a
# partir de POSTGRES_PASSWORD e LEPTOS_SITE_ADDR/ROOT/ENV já vêm da imagem.
# =====================================================================
# Senha do Postgres (obrigatória em prod; use algo forte e único).
POSTGRES_PASSWORD=troque-por-uma-senha-forte
# Porta do host (loopback) que o proxy reverso encaminha. Default 3000.
DRINKUP_APP_PORT=3000
# Domínio público do site é fixo em src/components/seo.rs (SITE_URL).
